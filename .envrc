#!/usr/bin/env bash

# Загрузка переменных окружения из .env файла
if [ -f .env ]; then
    # Загружаем переменные из .env файла
    export $(grep -v '^#' .env | xargs)
fi

# Если используется виртуальное окружение Python
if [ -d .venv ]; then
    source .venv/bin/activate
elif [ -d venv ]; then
    source venv/bin/activate
fi

